# Copy this file to `.env` and fill in. `.env` is gitignored.
#
# Etsy shop id (from the dashboard HTML: api/v3/ajax/shop/<SHOP_ID>/ ). Default is Matt's shop.
ETSY_SHOP_ID=22905049

# The shop's own Etsy user id — used to tell shop messages from buyer messages in convos.
ETSY_SHOP_SENDER_ID=288505356

# Set to "1" to actually write notes to Etsy. Unset / "0" = dry-run (log only, no writes).
# You can also pass --apply on the command line instead of setting this.
ETSY_APPLY=0

# Milliseconds to wait between order mutations (create/delete note). Etsy throttle.
ETSY_THROTTLE_MS=350

# Run the browser with a visible window (1) or headless (0). Headless is fine once
# the saved session works; use headed the first few times to watch it.
ETSY_HEADLESS=1

# --- JOB B: PAYRESPECTS ORDERS sheet sync -------------------------------------
# Deploy apps-script/payrespects-orders-sync.gs as a web app, then paste its
# /exec URL and the SECRET you set in that script here.
PAYRESPECTS_SHEET_EXEC_URL=
PAYRESPECTS_SHEET_SECRET=
# The tab (gid) within the PAYRESPECTS ORDERS sheet to write to.
PAYRESPECTS_SHEET_GID=728848446

# --- Optional: JOB C (remove DIGITIZE once digitized) -------------------------
# When enabled, the sweep reads the COBRA DIGITIZE sheet and strips the DIGITIZE
# token from any order whose STATUS is exactly READY or COMPLETED.
# Leave blank to skip JOB C entirely.
COBRA_SHEET_CSV_URL=
